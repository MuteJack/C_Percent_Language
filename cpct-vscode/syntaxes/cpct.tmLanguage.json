{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "C%",
  "scopeName": "source.cpct",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#chars" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#builtins" },
    { "include": "#functions" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.cpct",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.cpct",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.cpct",
              "match": "\\\\[nrt\\\\\"0]"
            }
          ]
        }
      ]
    },
    "chars": {
      "patterns": [
        {
          "name": "string.quoted.single.cpct",
          "match": "'(\\\\[nrt\\\\'0]|[^'\\\\])'",
          "captures": {
            "0": { "name": "string.quoted.single.cpct" }
          }
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.cpct",
          "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.cpct",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.cpct",
          "match": "\\b(if|else|while|do|for|return|break|continue)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.cpct",
          "match": "\\b(int|int8|int16|int32|int64|uint|uint8|uint16|uint32|uint64|intbig|bigint|float|float32|float64|char|string|bool|void|dict|map)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.cpct",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.cpct",
          "match": "\\b(print|println|input|len|shape|type|size|sort|sortkey|sortk|sortval|sortv|sortvk|to_string|to_char|to_int|to_float|divmod|keys|values|has|remove)(?=\\s*\\()"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.cpct",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.cpct",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.cpct",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.assignment.compound.cpct",
          "match": "(\\+=|-=|\\*=|/=|%=)"
        },
        {
          "name": "keyword.operator.assignment.cpct",
          "match": "="
        },
        {
          "name": "keyword.operator.increment-decrement.cpct",
          "match": "(\\+\\+|--)"
        },
        {
          "name": "keyword.operator.arithmetic.cpct",
          "match": "(\\+|-|\\*|/|%)"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.cpct",
          "match": "[;,]"
        },
        {
          "name": "punctuation.bracket.cpct",
          "match": "[{}()\\[\\]]"
        }
      ]
    }
  }
}

{
  // Comment style
  "comments": {
    "lineComment": "//"
  },

  // Bracket matching (highlighting, navigation)
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],

  // Auto-closing: inserts closing character when opening is typed
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] }
  ],

  // Wraps selected text when bracket/quote is typed
  "surroundingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" }
  ],

  // Code folding rules
  "folding": {
    "markers": {
      "start": "^\\s*\\{",
      "end": "^\\s*\\}"
    }
  },

  // Auto-indentation rules
  "indentationRules": {
    "increaseIndentPattern": "\\{\\s*$",   // Increase indent after {
    "decreaseIndentPattern": "^\\s*\\}"    // Decrease indent before }
  }
}

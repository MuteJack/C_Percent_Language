// Reference (ref) Test

// 1. Basic reference variable
int x = 10;
ref int r = x;
r = 20;
println(x);          // 20
println(r);        // 20

// 2. Function reference parameter (swap)
void swap(ref int a, ref int b) {
    int temp = a;
    a = b;
    b = temp;
}
int a = 1;
int b = 2;
swap(ref a, ref b);
println(a, b);       // 2 1

// 3. Reference of reference
ref int ref2 = r;
ref2 = 99;
println(x);          // 99

// 4. String reference
string s = "hello";
ref string sref = s;
sref = "world";
println(s);          // world

// 5. Modify via function
void append_exclaim(ref string str) {
    str = str + "!";
}
append_exclaim(ref s);
println(s);          // world!

// 6. Reference with various types
float f = 3.14;
ref float fref = f;
fref = 2.71;
println(f);          // 2.71

bool flag = true;
ref bool bref = flag;
bref = false;
println(flag);       // false

// 7. Vector reference
vector<int> v = [1, 2, 3];
ref vector<int> vref = v;
vref.push(4);
println(v);          // [1, 2, 3, 4]
println(len(v));     // 4

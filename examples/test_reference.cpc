// Reference (@) Test

// 1. Basic reference variable
int x = 10;
int@ ref = x;
ref = 20;
println(x);          // 20
println(ref);        // 20

// 2. Function reference parameter (swap)
void swap(int@ a, int@ b) {
    int temp = a;
    a = b;
    b = temp;
}
int a = 1;
int b = 2;
swap(@a, @b);
println(a, b);       // 2 1

// 3. Reference of reference
int@ ref2 = ref;
ref2 = 99;
println(x);          // 99

// 4. String reference
string s = "hello";
string@ sref = s;
sref = "world";
println(s);          // world

// 5. Modify via function
void append_exclaim(string@ str) {
    str = str + "!";
}
append_exclaim(@s);
println(s);          // world!

// 6. Reference with various types
float f = 3.14;
float@ fref = f;
fref = 2.71;
println(f);          // 2.71

bool flag = true;
bool@ bref = flag;
bref = false;
println(flag);       // false

// 7. Vector reference
vector<int> v = [1, 2, 3];
vector<int>@ vref = v;
vref.push(4);
println(v);          // [1, 2, 3, 4]
println(len(v));     // 4
